#!/usr/bin/env bash
# Wrapper to execute fnm's default npx binary reliably

FNM_DIR="$HOME/.local/share/fnm"
DEFAULT_ALIAS="$FNM_DIR/aliases/default"

# Resolve fnm default node via static symlinks
if [ -L "$DEFAULT_ALIAS" ]; then
  # Follow all symlinks to get the actual installation path
  TARGET=$(readlink -f "$DEFAULT_ALIAS")
  NPX_PATH="$TARGET/bin/npx"
  if [ -x "$NPX_PATH" ]; then
    exec "$NPX_PATH" "$@"
  fi
fi

# Fallback to known version if symlinks fail
NPX_PATH="$FNM_DIR/node-versions/v26.1.0/installation/bin/npx"
if [ -x "$NPX_PATH" ]; then
  exec "$NPX_PATH" "$@"
fi

echo "Error: Could not find fnm npx binary" >&2
exit 1
